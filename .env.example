# Application Identity 

APP_NAME = "Enterprise semantic RAG"
APP_VERSION =  "0.1.0"
DEBUG = false
LOG_LEVEL = INFO

#Data Paths

VECTOR_STORE_PATH = "./data/vector_store"

#Ingestion / chunking 

CHUNK_SIZE = 512
CHUNK_OVERLAP = 50

#Embedding model

EMBEDDING_MODEL_NAME = "sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DEVICE = auto

#Retrieval & Re-ranking
TOP_K_DENSE = 10
TOP_K_SPARSE
TOP_K_FINAL = 5
RERANKER_MODEL_NAME = "cross-encoder/ms-marco-MiniLM-L-6_v2"
CROSS_ENCODER_BATCH_SIZE = 32

#large language model

LLM_PROIDER = openai
LLM_MODELNAME = gpt-4o-mini
OPENAI_API_KEY = "your-actual-api-key-here"
OLLAMA_BASE_URL = http://localhost:11434
LLM_TEMPERATURE = 0.1
LLM_MAX_TOKENS= 1024

API_HOST = 0.0.0.0
API_PORT=8000


